# Copy this file to .env and fill in your values.
# Every variable listed here is read by backend/config/settings.py.
# Missing a required variable (DATABASE_URL) causes a named startup error.

# ── Database (Phase 0) ─────────────────────────────────────────────────────
# Pooler URL for all runtime queries (asyncpg)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# Direct (non-pooler) URL for Alembic migrations; falls back to DATABASE_URL
DATABASE_MIGRATION_URL=postgresql+asyncpg://user:password@host-direct/dbname

# ── Logging (Phase 0) ──────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Feature flags (Phase 0) — ALL default OFF ─────────────────────────────
# Flip to true only after paper/sandbox validation. See MASTER_PLAN.md.
ENABLE_ML_SIGNAL=false
ENABLE_LIVE_BROKER=false
ENABLE_AUTO_EXECUTION=false

# ── Leading-indicator flags (post-Phase 6 additions) — ALL default OFF ────
# Wire divergence into ai/signal_engine.py (NOT YET — no edge on NIFTY)
ENABLE_DIVERGENCE_SIGNAL=false
# Add rsi_divergence column to ml/features.py (REQUIRES MODEL RETRAIN before use)
ENABLE_DIVERGENCE_FEATURE=false
# Start the background poller that snapshots option chains into oi_snapshots
# (needed to forward-test OI Buildup; safe to enable in production)
ENABLE_OI_FLOW_LOGGING=false
# Seconds between OI snapshots when logging is enabled (NSE refreshes ~60s)
OI_SNAPSHOT_INTERVAL_SEC=60

# ── ML model version pin (Phase 2) ────────────────────────────────────────
# Leave empty to use the latest active model from model_registry.
# Set to e.g. "v1" to roll back to a specific trained version.
ML_MODEL_VERSION=

# ── External APIs ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
APP_ENV=development

# Twelve Data — real-time Indian market data (NIFTY + SENSEX), any IP/region
# Free tier: 800 calls/day. Leave blank to fall back to yfinance (15-min delay).
# Get key at https://twelvedata.com (free signup)
# Safe intervals to stay under 800/day: 5m (60s cache=375 calls) or 15m (120s cache=188 calls)
TWELVEDATA_API_KEY=

# ── Notifications (Phase 5) ───────────────────────────────────────────────
# Telegram — leave blank to disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP email — leave blank to disable
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Alert de-dup window in seconds (default 60)
ALERT_DEDUP_TTL=60

# ── Broker (Phase 4) ──────────────────────────────────────────────────────
# "paper" (default) or "live". ENABLE_LIVE_BROKER must also be true.
BROKER_MODE=paper
# Fernet key for encrypting Kite credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_ENCRYPTION_KEY=
# Per-install salt (any non-empty string). Makes ciphertexts install-unique.
BROKER_SALT=

# Kite Connect credentials (encrypted before storing; never stored in plaintext)
KITE_API_KEY=
KITE_ACCESS_TOKEN=
