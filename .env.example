# Copy to .env and fill in real values. Never commit .env to git.

# Neon Postgres connection strings
# Get from: console.neon.tech → your project → Connect → SQLAlchemy
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME
DATABASE_MIGRATION_URL=postgresql+asyncpg://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Feature flags — keep false until each phase is validated in paper mode
ENABLE_ML_SIGNAL=false
ENABLE_LIVE_BROKER=false
ENABLE_AUTO_EXECUTION=false
